   "source": [
    "# Crear columna grupo_edad\n",
    "import numpy as np\n",
    "\n",
    "user_profile['grupo_edad'] = np.where(\n",
    "    user_profile['age'] < 30, 'Joven',\n",
    "    np.where(user_profile['age'] < 60, 'Adulto', 'Adulto Mayor')\n",
    ")\n"
   ]
