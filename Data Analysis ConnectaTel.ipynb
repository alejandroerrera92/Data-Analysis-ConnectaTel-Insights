    "\n",
    "user_profile.loc[\n",
    "    (user_profile['cant_llamadas'] < 10) & (user_profile['cant_mensajes'] < 10) &\n",
    "    (user_profile['grupo_uso'] != 'Bajo uso'),\n",
    "    'grupo_uso'\n",
    "] = 'Uso medio'\n",
    "\n"
   ]
