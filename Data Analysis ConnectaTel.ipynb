    "\n",
    "# Crear columna grupo_uso\n",
    "user_profile['grupo_uso'] = 'Alto uso'\n",
    "\n",
    "user_profile.loc[\n",
    "    (user_profile['cant_llamadas'] < 5) & (user_profile['cant_mensajes'] < 5),\n",
    "    'grupo_uso'\n",
